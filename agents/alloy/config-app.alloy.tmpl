// Generated by agents/alloy/setup.sh (Phase 2C app scrape section)
// Appended when APP_METRICS_TARGET is set (e.g. "localhost:8090").
//
// Pipeline: backend /metrics → scrape → remote_write (shared with node)

////////////////////////////////////////////////////////////////////////////////
// 9. Scrape: application /metrics endpoint
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "app" {
  targets = [{
    __address__ = "${APP_METRICS_TARGET}",
    service     = "${PRODUCT}-backend",
  }]
  forward_to      = [prometheus.remote_write.central.receiver]
  scrape_interval = "15s"
  scrape_timeout  = "10s"
  job_name        = "${PRODUCT}-backend"
  metrics_path    = "/metrics"
  // If the app is slow on startup or reloads, avoid immediately flagging down
  honor_labels    = false
}
