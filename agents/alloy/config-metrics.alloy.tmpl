// Generated by agents/alloy/setup.sh (Phase 2B metrics section)
// Appended to config-logs.alloy.tmpl when PROM_PUSH_URL is set.
//
// Pipeline: node_exporter → scrape → remote_write → central Prometheus

////////////////////////////////////////////////////////////////////////////////
// 5. Source: node_exporter (host-level CPU/RAM/disk/net)
////////////////////////////////////////////////////////////////////////////////

prometheus.exporter.unix "node" {
  // Trim noisy or irrelevant collectors to keep cardinality low.
  // Full list: https://github.com/prometheus/node_exporter
  disable_collectors = [
    "arp",        // local ARP table — not useful for us
    "bcache",     // block cache — not used
    "btrfs",      // not used
    "entropy",    // /proc/sys/kernel/random/entropy_avail
    "hwmon",      // hardware sensors — not on EC2
    "ipvs",       // IP virtual server — not used
    "nfs",        // NFS client — not used
    "nfsd",       // NFS server — not used
    "nvme",       // NVMe devices — EBS is not NVMe at metric level
    "rapl",       // Intel RAPL power — not on ARM/cloud
    "thermal_zone",
    "xfs",        // XFS-specific — we use ext4
    "zfs",        // not used
  ]
}

////////////////////////////////////////////////////////////////////////////////
// 6. Scrape: local node_exporter once per 15s
////////////////////////////////////////////////////////////////////////////////

prometheus.scrape "node" {
  targets         = prometheus.exporter.unix.node.targets
  forward_to      = [prometheus.remote_write.central.receiver]
  scrape_interval = "15s"
  scrape_timeout  = "10s"
  job_name        = "node-exporter"
}

////////////////////////////////////////////////////////////////////////////////
// (Phase 2C app /metrics scrape lives in config-app.alloy.tmpl, appended by
// setup.sh when APP_METRICS_TARGET is set.)
////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////
// 8. Sink: central Prometheus via Cloudflare tunnel + Access Service Token
////////////////////////////////////////////////////////////////////////////////

prometheus.remote_write "central" {
  endpoint {
    url = "${PROM_PUSH_URL}"
    headers = {
      "CF-Access-Client-Id"     = "${CF_ACCESS_CLIENT_ID}",
      "CF-Access-Client-Secret" = "${CF_ACCESS_CLIENT_SECRET}",
    }

    // If the tunnel briefly flaps, buffer locally and retry
    queue_config {
      max_samples_per_send = 2000
      batch_send_deadline  = "5s"
      min_backoff          = "500ms"
      max_backoff          = "30s"
    }
  }

  external_labels = {
    product   = "${PRODUCT}",
    server_id = "${SERVER_ID}",
  }
}
