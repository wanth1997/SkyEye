# Copy to .env and fill in. .env is gitignored.
#
# NOTE: Credentials that get mounted as files (Telegram token, SMTP password,
# Cloudflare tunnel credentials) do NOT live here — they sit under
# alertmanager/secrets/ and cloudflared/credentials.json. This .env only
# holds variables that docker-compose needs as environment variables.

# --- Grafana admin ---
# 32+ char random string. Generate once, save in 1Password.
#   openssl rand -base64 32 | tr -d '+/=' | head -c 32
GF_ADMIN_PW=REPLACE_WITH_32_CHAR_RANDOM
