{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LokiBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::skyeye-loki-chunks"
    },
    {
      "Sid": "LokiObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::skyeye-loki-chunks/*"
    },
    {
      "Sid": "SnapshotsBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::skyeye-prometheus-snapshots"
    },
    {
      "Sid": "SnapshotsObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::skyeye-prometheus-snapshots/*"
    }
  ]
}
