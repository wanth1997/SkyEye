            "gradientMode": "opacity"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "🚨 Alerts",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 40,
      "type": "alertlist",
      "title": "Active & pending alerts",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 8
      },
      "options": {
        "showOptions": "current",
        "maxItems": 10,
        "sortOrder": 1,
        "dashboardAlerts": false,
        "alertName": "",
        "dashboardTitle": "",
        "tags": [],
