          "uid": "prometheus"
        },
        "query": {
          "query": "label_values(up{product!=\"\"}, product)",
          "refId": "StandardVariableQuery"
        },
        "definition": "label_values(up{product!=\"\"}, product)",
        "refresh": 1,
        "sort": 1,
