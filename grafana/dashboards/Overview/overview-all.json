{
  "uid": "overview-all",
  "title": "總覽 — 全產品",
  "tags": [
    "layer:overview",
    "provisioned"
  ],
  "editable": true,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "timezone": "",
  "style": "dark",
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 狀態總覽",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "被監測產品數",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count(sum by (product) (count_over_time({product=~\".+\"}[1h])))",
          "queryType": "instant",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "Distinct products with log activity in the last hour. Uses Loki (not Prom `up`) so products that haven't instrumented /metrics still count."
    },
    {
      "id": 11,
      "type": "stat",
      "title": "離線產品數",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(count(count by (product) (up{product!=\"\"} == 0)) OR on() vector(0))",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "現用告警(High/Medium)",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(ALERTS{alertstate=\"firing\",severity=~\"High|Medium\"}) OR on() vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "24 小時內寄出 Email",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(alertmanager_notifications_total{integration=\"email\"}[24h])) OR on() vector(0)",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "increase(alertmanager_notifications_total{integration=\"email\"}[24h]). Should be >= 1 per day — the DailyHeartbeat digest alone guarantees that. 0 for 24h+ means the Prom → AM → Gmail SMTP chain is broken."
    },

    {
      "id": 5,
      "type": "row",
      "title": "🚦 各產品健康度 — 一眼看",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 50,
      "type": "table",
      "title": "各產品 Traffic Light — 每列一個 product，紅/黃/綠立判",
      "description": "Up=Alloy/app metrics 是否流通；Req/s=HTTP 流量；5xx%=server error 比率(5m window)；p95=延遲 95 百分位；CPU/RAM/Disk=該產品所在 host。沒有 /metrics 的 product(例如 enyoung)會在這裡看不到 — 它們只出現在上方「被監測產品數」的 Loki 計數裡。",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max by (product, server_id) (up{job=~\".+-backend\"})",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (product) (rate(http_requests_total[5m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (sum by (product) (rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum by (product) (rate(http_requests_total[5m])), 0.0001))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1000 * histogram_quantile(0.95, sum by (product, le) (rate(http_request_duration_seconds_bucket[5m])))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "E",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 - (avg by (product) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "F",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - avg by (product) (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "format": "table",
          "instant": true
        },
        {
          "refId": "G",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(1 - avg by (product) (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "product", "mode": "outer" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "Time 7": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "service": true
            },
            "indexByName": {
              "product": 0,
              "server_id": 1,
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6,
              "Value #F": 7,
              "Value #G": 8
            },
            "renameByName": {
              "product": "Product",
              "server_id": "Server",
              "Value #A": "Up",
              "Value #B": "Req/s",
              "Value #C": "5xx %",
              "Value #D": "p95 (ms)",
              "Value #E": "CPU %",
              "Value #F": "RAM %",
              "Value #G": "Disk %"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "center" },
          "noValue": "—"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Up" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "✅", "color": "green", "index": 0 } } },
                  { "type": "value", "options": { "0": { "text": "❌", "color": "red", "index": 1 } } }
                ]
              },
              { "id": "custom.width", "value": 80 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Req/s" },
            "properties": [
              { "id": "unit", "value": "reqps" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "5xx %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 1 },
                    { "color": "red", "value": 5 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95 (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "decimals", "value": 0 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 500 },
                    { "color": "red", "value": 1500 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 70 },
                    { "color": "red", "value": 90 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 75 },
                    { "color": "red", "value": 90 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Disk %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 1 },
              {
                "id": "custom.cellOptions",
                "value": { "type": "color-background", "mode": "basic" }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 70 },
                    { "color": "red", "value": 85 }
                  ]
                }
              }
            ]
          }
        ]
      }
    },

