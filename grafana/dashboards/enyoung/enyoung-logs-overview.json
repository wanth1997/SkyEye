{
  "uid": "enyoung-logs-overview",
  "title": "enyoung — 日誌總覽",
  "tags": [
    "product:enyoung",
    "layer:logs",
    "provisioned"
  ],
  "editable": true,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 一眼速覽",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "24h 請求數",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({product=\"enyoung\"} [24h]))",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "enyoung 過去 24 小時接受的 HTTP 請求總數（從 access log 計算）"
    },
    {
      "id": 11,
      "type": "stat",
      "title": "5xx 錯誤率 (30m)",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({product=\"enyoung\"} | regexp `\"(?P<method>\\w+) (?P<url>\\S+) HTTP/\\S+\" from \\S+ - (?P<status>\\d+) (?P<bytes>\\d+)B in (?P<duration>\\S+)` | status =~ \"5..\" [30m])) / clamp_min(sum(count_over_time({product=\"enyoung\"} [30m])), 1)",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.05
              }
            ]
          },
          "decimals": 3,
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "過去 30 分鐘回應碼 5xx 的比率"
    },
    {
      "id": 12,
      "type": "stat",
      "title": "4xx 錯誤率 (30m)",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({product=\"enyoung\"} | regexp `\"(?P<method>\\w+) (?P<url>\\S+) HTTP/\\S+\" from \\S+ - (?P<status>\\d+) (?P<bytes>\\d+)B in (?P<duration>\\S+)` | status =~ \"4..\" [30m])) / clamp_min(sum(count_over_time({product=\"enyoung\"} [30m])), 1)",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 0.3
              }
            ]
          },
          "decimals": 3,
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "過去 30 分鐘回應碼 4xx 的比率（未登入 / 找不到 / 驗證失敗等）"
    },
    {
      "id": 13,
      "type": "stat",
      "title": "最近 10 分鐘請求數",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({product=\"enyoung\"} [10m]))",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "decimals": 0,
          "noValue": "0"
        },
        "overrides": []
      },
      "description": "近 10 分鐘 log 請求數。0 代表 enyoung 沒在接收請求（可能掛了、可能是低流量時段）"
    },
    {
      "id": 2,
      "type": "row",
      "title": "📈 請求趨勢",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "請求速率（每分鐘）",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(rate({product=\"enyoung\"} [1m])) * 60",
          "legendFormat": "req/min",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "各狀態碼分布（req/min）",
      "gridPos": {
        "x": 12,
        "y": 6,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (status) (rate({product=\"enyoung\"} | regexp `\"(?P<method>\\w+) (?P<url>\\S+) HTTP/\\S+\" from \\S+ - (?P<status>\\d+) (?P<bytes>\\d+)B in (?P<duration>\\S+)` [1m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "🗺️ 流量分布",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "各 method 請求速率",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (method) (rate({product=\"enyoung\"} | regexp `\"(?P<method>\\w+) (?P<url>\\S+) HTTP/\\S+\" from \\S+ - (?P<status>\\d+) (?P<bytes>\\d+)B in (?P<duration>\\S+)` [5m])) * 60",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "never"
          },
          "noValue": "0"
        },
        "overrides": []
      }
    },
    {
      "id": 31,
      "type": "table",
      "title": "Top 10 請求路徑（近 1 小時）",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(10, sum by (url) (count_over_time({product=\"enyoung\"} | regexp `\"(?P<method>\\w+) (?P<url>\\S+) HTTP/\\S+\" from \\S+ - (?P<status>\\d+) (?P<bytes>\\d+)B in (?P<duration>\\S+)` [1h])))",
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "請求數",
              "url": "路徑"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "📝 最近 log",
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 40,
      "type": "logs",
      "title": "enyoung 最新 50 行 log",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{product=\"enyoung\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      }
    }
  ],
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  }
}