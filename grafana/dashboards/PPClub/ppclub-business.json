          "expr": "(sum(increase(ppc_payment_success_total{product=\"$product\"}[24h])) OR on() vector(0)) / clamp_min((sum(increase(ppc_payment_created_total{product=\"$product\"}[24h])) OR on() vector(0)), 1)",
