      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (currency) (rate({product=\"zenincome\"} | regexp `(?:for |Symbol=|for fUSD|for f)(?P<currency>[A-Z]+)` [5m])) * 60",
          "legendFormat": "{{currency}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
