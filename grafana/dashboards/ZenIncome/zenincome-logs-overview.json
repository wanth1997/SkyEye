{
  "uid": "zenincome-logs-overview",
  "title": "ZenIncome — 日誌總覽",
  "tags": [
    "product:zenincome",
    "layer:logs",
    "provisioned"
  ],
  "editable": true,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "🟢 一眼速覽",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "stat",
      "title": "24h log 總數",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({product=\"zenincome\"} [24h]))",
          "refId": "A",
          "queryType": "instant",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "description": "ZenIncome 過去 24 小時 log 行數 — 流量估計"
    },
    {
      "id": 11,
      "type": "stat",
      "title": "30m ERROR 數",
      "gridPos": {
        "x": 5,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
