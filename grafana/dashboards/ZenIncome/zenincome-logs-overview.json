          },
          "expr": "sum(rate({product=\"zenincome\"} |= \"[INFO]\" [1m])) * 60",
          "legendFormat": "INFO",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(rate({product=\"zenincome\"} |= \"[WARN]\" [1m])) * 60",
