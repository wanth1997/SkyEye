        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(rate({product=\"zenincome\"} |= \"[ERROR]\" [1m])) * 60",
          "legendFormat": "ERROR",
          "refId": "C"
        }
