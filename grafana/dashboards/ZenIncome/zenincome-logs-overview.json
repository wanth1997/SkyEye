      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          },
          "decimals": 0
        },
        "overrides": []
      },
      "description": "近 30 分鐘 ERROR 級 log 數。> 0 值得注意，> 10 該警戒"
