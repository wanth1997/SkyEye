    {
      "id": 4,
      "type": "row",
      "title": "🗺️ 來源熱點",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 40,
      "type": "table",
      "title": "Top 10 log 來源（file.go:line）",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(10, sum by (source) (count_over_time({product=\"zenincome\"} | regexp `\\s(?P<source>[\\w./-]+\\.go:\\d+):` [1h])))",
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "log 數",
              "source": "來源"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 41,
      "type": "table",
      "title": "ERROR / WARN 的 Top 訊息片段（近 1h）",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(10, sum by (source) (count_over_time({product=\"zenincome\"} |~ \"\\\\[(ERROR|WARN)\\\\]\" | regexp `\\s(?P<source>[\\w./-]+\\.go:\\d+):` [1h])))",
          "refId": "A",
          "queryType": "instant",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "次數",
              "source": "來源"
            }
          }
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
